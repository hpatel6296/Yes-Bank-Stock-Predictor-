import matplotlib.pyplot as plt
import seaborn as sns

# 1. Calculate Daily_Range
df['Daily_Range'] = df['High'] - df['Low']

# 2. Create a line plot showing the Daily_Range over time
plt.figure(figsize=(16, 8))
sns.lineplot(x='Date', y='Daily_Range', data=df, label='Daily Range', color='blue')

# 3. Add a vertical line to demarcate the period before and after 2018
# Find the date corresponding to the beginning of 2018
first_2018_date = df[df['Year'] == 2018]['Date'].min()
plt.axvline(x=first_2018_date, color='red', linestyle='--', label='Start of 2018 (Increased Volatility)')

# 4. Add a title to the plot
plt.title('Daily Price Range (Volatility) Over Time', fontsize=16)

# 5. Label the x-axis and y-axis
plt.xlabel('Date', fontsize=12)
plt.ylabel('Daily Range (High - Low)', fontsize=12)

# 6. Add a legend
plt.legend(fontsize=10)

# Add grid for better readability
plt.grid(True, linestyle='--', alpha=0.7)

# Adjust x-axis tick labels for better readability
plt.xticks(rotation=45, ha='right')

# 7. Display the plot
plt.tight_layout()
plt.show()
